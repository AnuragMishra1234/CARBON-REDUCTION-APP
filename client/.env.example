# ─────────────────────────────────────────────────────────────
#  Carbon AI – Client Environment Variables
#  Copy this file to .env.local for local development
#  Set these in the Vercel dashboard for production
# ─────────────────────────────────────────────────────────────

# Backend API base URL
# LOCAL DEV:   Leave EMPTY — Vite proxy forwards /api to localhost:5000
#              Do NOT set this to http://localhost:5000 in Vercel dashboard!
# PRODUCTION:  Set to your Render URL in Vercel dashboard, e.g.:
#              https://carbon-ai-backend.onrender.com
VITE_API_URL=
