# ─────────────────────────────────────────────────────────────
#  Carbon AI – Server Environment Variables
#  Copy this file to .env for local development
#  Set all values in the Render dashboard for production
# ─────────────────────────────────────────────────────────────

# Server port (Render injects 10000 automatically)
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/carbon_ai?retryWrites=true&w=majority

# JWT secret – use a long random string in production!
JWT_SECRET=carbon_ai_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# Groq AI API key – get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Environment
NODE_ENV=development

# Frontend URL (CORS allow-list)
# Local:       http://localhost:5173
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
